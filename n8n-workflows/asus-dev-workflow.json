    {
      "parameters": {
        "httpMethod": "POST",
        "path": "jira-inprogress",
        "options": {}
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [0, 0],
      "id": "d77b8285-cba8-4b31-a3ea-3bc2d03190c2",
      "name": "Webhook",
      "webhookId": "4ddc611a-fc45-47a9-82fc-fb36cd6076bf"
    },
    {
      "parameters": {
        "jsCode": "const payload = $input.first().json.body ?? $input.first().json;\nconst issue = payload.issue ?? {};\nconst fields = issue.fields ?? {};\n\nconst status = fields.status?.name ?? '';\nif (status !== 'In Progress') {\n  return [];\n}\n\nconst descText = JSON.stringify(fields.description ?? '');\nconst tddMatch = descText.match(/測試命名[：:]\\s*`?([^`\\n\"]+)`?/);\nconst tddDod = tddMatch ? tddMatch[1].trim() : '';\n\nconst slugMatch = descText.match(/Spec[：:][^\\n]*?\\/([^\\/\\s\"]+)\\.md/);\nconst slug = slugMatch ? slugMatch[1] : '';\n\nreturn [{\n  json: {\n    jiraKey: issue.key ?? '',\n    summary: fields.summary ?? '',\n    tddDod,\n    slug,\n    jiraUrl: `https://prostyliu.atlassian.net/browse/${issue.key}`,\n    issueId: issue.id ?? '',\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [192, 0],
      "id": "1963cf20-bb79-4b6a-8c87-6484f84a9338",
      "name": "解析票面"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:3001/read-file",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"filePath\": \"D:\\\\06_Workspace\\\\Workspace_GitHub\\\\xu3clayu83ire\\\\alag-addyosmani-demos\\\\awtw-short-url-service\\\\_spec\\\\phase3-ai-agent\\\\spec.md\"\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [368, 0],
      "id": "9f16374e-2980-461f-97e3-3ccf7674f1f9",
