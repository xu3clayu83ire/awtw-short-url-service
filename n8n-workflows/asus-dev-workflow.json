        "jsCode": "const response = $input.first().json;\nconst transitions = response.transitions || [];\nconst target = transitions.find(t =>\n  t.name === 'In Review' ||\n  t.name === 'Review' ||\n  (t.to && t.to.name === 'In Review')\n);\n\nif (!target) {\n  const names = transitions.map(t => t.name).join(', ');\n  throw new Error('找不到 In Review 轉換。可用轉換：' + names);\n}\n\nconst prev = $('準備所有 Bodies').first().json;\nreturn [{\n  json: {\n    jiraKey: prev.jiraKey,\n    jiraTransitionId: target.id,\n    slug: prev.slug,\n    taskId: prev.taskId,\n    sourceFile: prev.sourceFile,\n  }\n}];"
      },
