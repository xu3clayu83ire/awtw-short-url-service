    {
      "parameters": {
        "jsCode": "const taskId = $('解析票面').first().json.taskId;\nconst files = [\n  { name: 'tasks-backend.md', content: $('讀取 tasks-backend.md').first().json.content },\n  { name: 'tasks-devops.md', content: $('讀取 tasks-devops.md').first().json.content },\n  { name: 'tasks-qa.md', content: $('讀取 tasks-qa.md').first().json.content },\n];\n\nfunction extractBlock(content, id) {\n  if (!content) return null;\n  const startRe = new RegExp('^### ' + id + ' — ', 'm');\n  const startMatch = content.match(startRe);\n  if (!startMatch) return null;\n  const startIdx = startMatch.index;\n  const rest = content.slice(startIdx);\n  const firstNewline = rest.indexOf('\\n');\n  const remainder = firstNewline >= 0 ? rest.slice(firstNewline + 1) : '';\n  const nextMatch = remainder.match(/\\n### T\\d+ /);\n  const block = nextMatch ? rest.slice(0, firstNewline + 1 + nextMatch.index) : rest;\n  return block.trim();\n}\n\nif (!taskId) {\n  throw new Error('票面缺少 TaskId，無法定位任務區塊（檢查 Jira Description 是否有 TaskId：<slug>#<taskId> 這行）');\n}\n\nfor (const file of files) {\n  const block = extractBlock(file.content, taskId);\n  if (block) {\n    return [{ json: { taskBody: block, sourceFile: file.name } }];\n  }\n}\n\nthrow new Error(`找不到 TaskId=${taskId} 對應的任務區塊，檢查三份 tasks-*.md 檔案`);"
      },
