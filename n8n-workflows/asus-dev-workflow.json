    {
      "parameters": {
        "jsCode": "const taskId = $('解析 Jira Transition').first().json.taskId;\nconst jiraKey = $('解析 Jira Transition').first().json.jiraKey;\nconst slug = $('解析 Jira Transition').first().json.slug;\nconst content = $input.first().json.content ?? '';\nconst filePath = $input.first().json.filePath;\n\nconst headerRegex = new RegExp('(### ' + taskId + ' — .+?)⬜(.*)$', 'm');\nif (!headerRegex.test(content)) {\n  throw new Error(`找不到 ${taskId} 對應的 ⬜ 標頭，可能已經是 ✅ 或格式跑掉，需要人工確認 ${filePath}`);\n}\n\n// 票號註記已在開票階段（T15 回填任務票號）寫入，這裡只需要把圖示改成 ✅，不可重複加註票號\nconst updated = content.replace(headerRegex, (match, before, after) => {\n  return before + '✅' + after;\n});\n\nreturn [{ json: { filePath, content: updated, taskId, jiraKey, slug } }];"
