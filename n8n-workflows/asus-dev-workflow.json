    {
      "parameters": {
        "jsCode": "const payload = $input.first().json.body ?? $input.first().json;\nconst issue = payload.issue ?? {};\nconst fields = issue.fields ?? {};\n\nconst status = fields.status?.name ?? '';\nif (status !== 'In Progress') {\n  return [];\n}\n\nconst summary = fields.summary ?? '';\nconst descText = JSON.stringify(fields.description ?? '');\n\n// 手動票略過，不觸發 Claude API（2026-07-05 修訂：改讀票面 ExecMode：欄位，不再依賴 summary 裡的 [手動] 字樣，因為新版標題不含執行方式標籤）\nconst execModeMatch = descText.match(/ExecMode[：:]\\s*([^\\s\"\\\\]+)/);\nconst execMode = execModeMatch ? execModeMatch[1] : '';\nif (execMode.includes('手動')) {\n  return [];\n}\n\nconst tddMatch = descText.match(/測試命名[：:]\\s*`?([^`\\n\"]+)`?/);\nconst tddDod = tddMatch ? tddMatch[1].trim() : '';\n\nconst slugMatch = descText.match(/Slug[：:]\\s*([^\\s\"\\\\]+)/);\nconst slug = slugMatch ? slugMatch[1] : '';\n\nconst taskIdMatch = descText.match(/TaskId[：:]\\s*[^\\s#\"\\\\]+#(T\\d+)/);\nconst taskId = taskIdMatch ? taskIdMatch[1] : '';\n\nreturn [{\n  json: {\n    jiraKey: issue.key ?? '',\n    summary,\n    tddDod,\n    slug,\n    taskId,\n    jiraUrl: `https://prostyliu.atlassian.net/browse/${issue.key}`,\n    issueId: issue.id ?? '',\n  }\n}];"
      },
